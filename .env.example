# Copy to .env and fill in (never commit .env)
# Classic PAT: enable scopes "repo" and "workflow" (workflow needed to push Actions YAML)
GITHUB_TOKEN=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=
# Optional
ANTHROPIC_API_KEY=
# Optional: only if this repo is not your GitHub Pages site (see full_automation_system.py)
# GITHUB_REPO=owner/repo
# WEBSITE_URL=https://owner.github.io
